+  const payload = {
+    chat_id: String(chatId),
+    message_id: Number(messageId),
+    text: String(text || ''),
+    parse_mode: 'HTML',
+    disable_web_page_preview: Boolean(disablePreview)
+  };
+  if (replyMarkup) payload.reply_markup = replyMarkup;
+  try {
+    return telegramApi_('editMessageText', payload);
