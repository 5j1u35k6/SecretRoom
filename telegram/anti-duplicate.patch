-function answerCallback_(callbackQueryId) {
-  try { telegramApi_('answerCallbackQuery', { callback_query_id: callbackQueryId }); } catch (_) {}
+function answerCallback_(callbackQueryId, text) {
+  const payload = { callback_query_id: callbackQueryId, cache_time: 1 };
+  if (text) payload.text = String(text).slice(0, 180);
+  try { telegramApi_('answerCallbackQuery', payload); } catch (_) {}
+}
+
+function claimTelegramUpdate_(update) {
+  const updateId = update?.update_id;
+  const fallback = update?.callback_query?.id || update?.message?.message_id;
+  const keyPart = updateId !== undefined && updateId !== null ? String(updateId) : String(fallback || '');
+  if (!keyPart) return true;
+  return claimCacheKey_(`sr_tg_update_${keyPart}`, SR_TG.updateDedupSeconds);
+}
+
+function claimCallbackAction_(query) {
+  const chatId = query?.message?.chat?.id;
+  const messageId = query?.message?.message_id;
+  const data = String(query?.data || '');
+  if (!chatId || !messageId || !data) return true;
+  return claimCacheKey_(`sr_tg_action_${chatId}_${messageId}_${data}`, SR_TG.actionDebounceSeconds);
+}
+
+function claimCacheKey_(key, seconds) {
+  const cache = CacheService.getScriptCache();
+  if (cache.get(key)) return false;
+  const lock = LockService.getScriptLock();
+  if (!lock.tryLock(3000)) return false;
+  try {
+    if (cache.get(key)) return false;
+    cache.put(key, '1', Math.max(1, Math.min(Number(seconds) || 1, 21600)));
+    return true;
+  } finally {
+    lock.releaseLock();
+  }
 }
