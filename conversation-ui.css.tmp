/* SecretRoom conversation interface v1 */
.sr-conversation-panel{position:relative;display:flex;flex-direction:column;gap:.75rem;padding-top:1rem!important;border-top:1px solid rgba(245,158,11,.14)!important}
.sr-conversation-header{display:flex;align-items:flex-end;justify-content:space-between;gap:1rem;padding:0 .15rem}
.sr-conversation-header>div{display:flex;align-items:baseline;gap:.55rem}.sr-conversation-header strong{font-size:.82rem;color:#f8fafc;letter-spacing:.04em}.sr-conversation-header span{font-size:.68rem;color:#64748b}.sr-conversation-hint{white-space:nowrap}
.sr-conversation-list{display:flex;flex-direction:column;gap:.7rem;min-height:5rem;max-height:min(22rem,42vh);overflow-y:auto;overscroll-behavior:contain;scrollbar-gutter:stable;padding:.35rem .3rem .5rem;scroll-behavior:smooth}
.sr-conversation-message{display:flex;align-items:flex-end;gap:.55rem;max-width:92%}.sr-conversation-message.is-own{align-self:flex-end;flex-direction:row-reverse}.sr-conversation-message.is-other{align-self:flex-start}
.sr-conversation-avatar{width:1.9rem;height:1.9rem;flex:0 0 auto;border-radius:999px;object-fit:cover;border:1px solid rgba(245,158,11,.2);background:#020617}.sr-conversation-message-body{min-width:0;max-width:100%}
.sr-conversation-meta{display:flex;align-items:center;gap:.35rem;margin:0 .25rem .25rem;font-size:.62rem;color:#64748b;min-height:1rem}.is-own .sr-conversation-meta{justify-content:flex-end}.sr-conversation-author{font-weight:800;color:#cbd5e1}.sr-conversation-account{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;color:#64748b}.sr-conversation-meta time{margin-left:auto;white-space:nowrap}.is-own .sr-conversation-meta time{margin-left:0}
.sr-conversation-action button{display:grid;place-items:center;width:1.45rem;height:1.45rem;border-radius:999px;color:#64748b;transition:.18s ease}.sr-conversation-action button:hover{background:rgba(244,63,94,.1);color:#fda4af}
.sr-conversation-bubble{padding:.68rem .82rem;border-radius:1.05rem;font-size:.78rem;line-height:1.55;overflow-wrap:anywhere;white-space:normal;box-shadow:0 8px 24px rgba(0,0,0,.14)}
.is-other .sr-conversation-bubble{color:#e2e8f0;background:rgba(15,23,42,.88);border:1px solid rgba(148,163,184,.12);border-bottom-left-radius:.35rem}.is-own .sr-conversation-bubble{color:#fff7ed;background:linear-gradient(135deg,rgba(180,83,9,.72),rgba(120,53,15,.78));border:1px solid rgba(251,191,36,.2);border-bottom-right-radius:.35rem}
.sr-conversation-empty{display:flex;min-height:7rem;flex-direction:column;align-items:center;justify-content:center;gap:.3rem;color:#64748b;text-align:center}.sr-conversation-empty i{font-size:1.25rem;color:rgba(245,158,11,.5)}.sr-conversation-empty strong{font-size:.75rem;color:#94a3b8}.sr-conversation-empty span{font-size:.66rem}
.sr-conversation-composer{position:sticky;bottom:0;z-index:5;display:grid!important;grid-template-columns:minmax(0,1fr) auto;align-items:end;gap:.55rem!important;padding:.65rem;padding-bottom:max(.65rem,env(safe-area-inset-bottom));border:1px solid rgba(245,158,11,.12);border-radius:1rem;background:rgba(2,6,23,.94);box-shadow:0 -10px 30px rgba(0,0,0,.18);backdrop-filter:blur(14px)}
.sr-conversation-input{width:100%;min-height:2.55rem;max-height:7.5rem;resize:none;overflow-y:auto;border:1px solid rgba(148,163,184,.13);border-radius:.8rem;background:rgba(15,23,42,.78);padding:.72rem .8rem;color:#f8fafc;font-size:.78rem;line-height:1.45;outline:none;transition:.18s ease}.sr-conversation-input:focus{border-color:rgba(34,211,238,.45);box-shadow:0 0 0 3px rgba(34,211,238,.08)}.sr-conversation-input::placeholder{color:#64748b}
.sr-conversation-send{display:inline-flex;align-items:center;justify-content:center;gap:.4rem;min-width:4.5rem;min-height:2.55rem;padding:.65rem .85rem;border-radius:.8rem;background:linear-gradient(135deg,#d97706,#f59e0b);color:#111827;font-size:.72rem;font-weight:900;box-shadow:0 8px 20px rgba(180,83,9,.2);transition:.18s ease}.sr-conversation-send:hover{filter:brightness(1.08);transform:translateY(-1px)}.sr-conversation-send:disabled{transform:none;filter:none}.sr-conversation-count{grid-column:1/-1;justify-self:end;margin-top:-.25rem;padding-right:.2rem;font-size:.6rem;color:#64748b}
@media(max-width:640px){.sr-conversation-header{align-items:flex-start}.sr-conversation-hint{display:none}.sr-conversation-list{max-height:min(20rem,38vh);padding-inline:.05rem}.sr-conversation-message{max-width:96%}.sr-conversation-avatar{width:1.75rem;height:1.75rem}.sr-conversation-account{display:none}.sr-conversation-bubble{font-size:.76rem}.sr-conversation-composer{grid-template-columns:minmax(0,1fr) 2.65rem;padding:.5rem;padding-bottom:max(.5rem,env(safe-area-inset-bottom))}.sr-conversation-send{min-width:2.65rem;width:2.65rem;padding:0}.sr-conversation-send span{display:none}}
